{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "List(*)",
      "Fetch(https://*)",
      "Bash(ls:*)",
      "Bash(diff:*)",
      "Bash(tree:*)",
      "Bash(go:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(jj:*)"
    ],
    "deny": []
  },
  "statusLine": {
    "type": "command",
    "command": "ccusage statusline"
  },
  "enabledPlugins": {
    "aws-common@aws-skills": true,
    "aws-cdk@aws-skills": true,
    "gopls-lsp@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "go-skills@golang-skills": true,
    "slack@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "opentelemetry-instrumentation@cedricziel-claude-otel-plugin": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "cedricziel-claude-otel-plugin": {
      "source": {
        "source": "github",
        "repo": "cedricziel/claude-otel-plugin"
      }
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754045417784
  }
}
